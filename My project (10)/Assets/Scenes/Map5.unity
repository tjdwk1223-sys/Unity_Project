  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 956a242953740f146a8e78a13a958f6b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  interactUI: {fileID: 700823227}
  dialogueManager: {fileID: 1118566448}
  mushroomObj: {fileID: 1618596456}
  anim: {fileID: 683945693}
  yesButton: {fileID: 592527995}
  noButton: {fileID: 875659257}
  talk_Intro:
  - "\uC548\uB155? \uB09C \uBAA8\uBAA8\uC57C."
  - "\uBC30\uAC00 \uB108\uBB34 \uACE0\uD508\uB370... \uC800\uAE30 \uC6B8\uD0C0\uB9AC
    \uB108\uBA38 \uC704\uD5D8\uD55C \uACF3\uC5D0 \uBC84\uC12F \uC880 \uAC00\uC838\uB2E4\uC904
    \uC218 \uC788\uC5B4?"
  talk_Thinking:
  - "\uD750\uC74C... \uC0DD\uAC01 \uC880 \uD574\uBD24\uC5B4?"
  - "\uB0B4 \uBD80\uD0C1 \uB4E4\uC5B4\uC904 \uAC70\uC57C?"
  talk_Accepted:
  - "\uACE0\uB9C8\uC6CC! \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC744\uAC8C! \uBE68\uB9AC
    \uB2E4\uB140\uC640~"
  talk_Ing:
  - "\uC544\uC9C1\uC774\uC57C? \uBC30\uAC00 \uB4F1\uAC00\uC8FD\uC5D0 \uBD99\uACA0\uC5B4..."
  talk_Success1:
  - "\uC640! \uC9C4\uC9DC \uAC00\uC838\uC654\uAD6C\uB098! \uB0E0\uB0E0..."
  - "\uC74C... \uADFC\uB370 \uC544\uC9C1 \uBC30\uAC00 \uB35C \uCC3C\uC5B4."
  - "\uC9C4\uC9DC \uBBF8\uC548\uD55C\uB370 \uB531 \uD55C \uBC88\uB9CC \uB354 \uB2E4\uB140\uC640
    \uC904 \uC218 \uC788\uC5B4?"
  talk_Refuse2:
  - "\uC7A5\uB09C\uD558\uB0D0?"
  - "\uB18D\uB2F4\uC774\uACE0~ \uC54C\uACA0\uC5B4, \uC774\uBC88\uC774 \uC9C4\uC9DC
    \uB9C8\uC9C0\uB9C9\uC774\uC57C! \uBD80\uD0C1\uD574!"
  talk_Success2:
  - "\uAEBC\uC5B5~ \uC798 \uBA39\uC5C8\uB2E4!"
  - "\uB355\uBD84\uC5D0 \uC0B4\uC558\uC5B4. \uB108 \uC815\uB9D0 \uCC29\uD55C \uC544\uC774\uAD6C\uB098?"
  - "\uC774\uC81C \uC9D1\uC73C\uB85C \uB3CC\uC544\uAC00\uB3C4 \uC88B\uC544. \uC798
    \uAC00!"
  state: 0
  hasItem: 0
